# Copilot Studio Agent (Phase A — Test Case Writer)
# מ-Copilot Studio: Settings -> Advanced -> Metadata
COPILOT_ENVIRONMENT_ID=
COPILOT_AGENT_IDENTIFIER=
COPILOT_TENANT_ID=
COPILOT_APP_CLIENT_ID=
COPILOT_CLOUD=PROD
COPILOT_AGENT_TYPE=PUBLISHED
# אופציונלי: Connection string מ-Copilot Studio -> Channels -> Native app.
# אם מסופק — מחליף את environment_id/cloud (אבל TENANT_ID + APP_CLIENT_ID עדיין נדרשים ל-MSAL).
COPILOT_DIRECT_CONNECT_URL=
# Embed URL (fallback) מ-Copilot Studio -> Channels -> Web app -> Embed code (iframe src)
COPILOT_WEBCHAT_URL=
# ★ Token endpoint (מסלול ראשי) מ-Copilot Studio -> Channels -> Custom website / Mobile app
# מאפשר Custom Canvas עם file upload + auto JSON detection
COPILOT_TOKEN_ENDPOINT=
# ★ Token endpoint נפרד עבור מחלקת .NET (Kafka/Couchbase Worker tests) — Copilot Studio שני
DOTNET_COPILOT_TOKEN_ENDPOINT=
# ★ Token endpoint של סוכן Payload Builder (Copilot Studio) — מקבל את האפיון ומחזיר templates+field_catalog.
# אם ריק → Compiler עובד במצב regex-only (כמו לפני התוספת).
DOTNET_PAYLOAD_COPILOT_TOKEN_ENDPOINT=
DOTNET_PAYLOAD_BUILDER_TIMEOUT_SECONDS=180
# WebSocket: True = סטרימינג אמיתי מילה-מילה. False = HTTP polling (אם רשת ארגונית חוסמת WebSocket).
COPILOT_USE_WEBSOCKET=true
# Polling interval (ms) — רלוונטי רק כש-COPILOT_USE_WEBSOCKET=false. נמוך = יותר תכוף = קרוב לסטרימינג.
COPILOT_POLLING_INTERVAL_MS=300

# .NET department — Kafka direct (confluent-kafka)
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_CONSUMER_GROUP_PREFIX=qa-ai-hero
# שם consumer group מדויק. אם ה-ACL שלך הוא literal (group ספציפי, לא prefix) — הגדר אותו כאן
# (ללא suffix אקראי). ריק → PREFIX + suffix אקראי. ⚠ אל תשתמש ב-group של ה-Worker בפרודקשן.
KAFKA_CONSUMER_GROUP=
KAFKA_DEFAULT_TIMEOUT_SECONDS=30
# רצפת המתנה ל-kafka_wait — ה-Worker אסינכרוני (עד דקה-שתיים). early-return כשנמצא match.
KAFKA_WAIT_MIN_SECONDS=150
# ★ Confluent REST Proxy (מומלץ) — אם מאוכלס, publish+consume דרך HTTP במקום הקליינט הנייטיב.
# עוקף בעיות ACL/cert של librdkafka. ה-Basic-Auth דיפולטית = KAFKA_SASL_USERNAME/PASSWORD.
KAFKA_REST_PROXY_URL=
KAFKA_REST_USERNAME=
KAFKA_REST_PASSWORD=

# .NET department — Couchbase direct
COUCHBASE_CONNECTION_STRING=
COUCHBASE_USERNAME=
COUCHBASE_PASSWORD=
COUCHBASE_DEFAULT_TIMEOUT_SECONDS=30
# אופציות אימות: interactive | device_code | client_secret | token
COPILOT_AUTH_MODE=interactive
COPILOT_CLIENT_SECRET=
COPILOT_TOKEN=

# Azure AI Foundry — מסלול חלופי לכתיבת test cases (אופציונלי)
# אם מאוכלס — כפתור "Foundry mode" יופיע ב-UI ויעקוף את Copilot Studio.
AZURE_FOUNDRY_ENDPOINT=
FOUNDRY_WRITER_AGENT_ID=
# אימות: browser (פותח דפדפן בריצה ראשונה) | device_code (CLI code) | default (chain)
FOUNDRY_AUTH_MODE=browser

# Azure OpenAI (Phase B — parser/validator/bug analysis)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt51-qa
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure DevOps
ADO_ORG_URL=
ADO_PROJECT=
ADO_PAT=

# Runner Mode
RUNNER_MODE=mock
PLAYWRIGHT_HEADLESS=true
VERIFY_SSL=true

# Confluent Control Center
CONFLUENT_URL=
CONFLUENT_USERNAME=
CONFLUENT_PASSWORD=

# Kibana
KIBANA_URL=
KIBANA_USERNAME=
KIBANA_PASSWORD=

# HTTP API timeout (Postman runner)
HTTP_TIMEOUT_SECONDS=30

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
